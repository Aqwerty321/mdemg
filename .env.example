# MDEMG Service Configuration
# Copy this file to .env and fill in your values

# Neo4j Connection (required)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=your_password_here

# Schema version (required - must match applied migrations)
REQUIRED_SCHEMA_VERSION=4

# Service
LISTEN_ADDR=:9999

# Dynamic Port Allocation (optional)
# If LISTEN_ADDR port is busy, server scans this range for an available port.
# PORT_RANGE_START=9999         # Start of fallback range (default: derived from LISTEN_ADDR)
# PORT_RANGE_END=10099          # End of fallback range (default: PORT_RANGE_START + 100)
# PORT_FILE_PATH=.mdemg.port   # Port file for client discovery (default: .mdemg.port)

# Retrieval tuning
VECTOR_INDEX_NAME=memNodeEmbedding
DEFAULT_CANDIDATE_K=200
DEFAULT_TOP_K=20
DEFAULT_HOP_DEPTH=2
MAX_NEIGHBORS_PER_NODE=50
MAX_TOTAL_EDGES_FETCHED=5000
LEARNING_EDGE_CAP_PER_REQUEST=200

# Embedding Provider: "openai", "ollama", or "" (disabled)
EMBEDDING_PROVIDER=ollama

# OpenAI settings (if EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=text-embedding-ada-002
OPENAI_ENDPOINT=https://api.openai.com/v1

# Ollama settings (if EMBEDDING_PROVIDER=ollama)
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text

# Embedding Cache (LRU caching of embedding results)
EMBEDDING_CACHE_ENABLED=true   # Enable caching (default: true)
EMBEDDING_CACHE_SIZE=1000       # Max cached embeddings (default: 1000)
EMBEDDING_CACHE_DEBUG=false     # Enable debug logging for cache hits/misses (default: false)

# Temporal Retrieval (time-aware query understanding)
TEMPORAL_ENABLED=true           # Enable temporal query detection (default: true)
TEMPORAL_SOFT_BOOST=3.0         # Recency weight multiplier for soft-mode queries (default: 3.0, range: 1.0-10.0)
TEMPORAL_HARD_FILTER=true       # Enable hard time-range filtering (default: true)

# Linear Integration (for linear-module plugin)
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINEAR_TEAM_ID=                 # Default team key for issue creation (e.g., "ENG")
LINEAR_WORKSPACE_ID=            # Workspace identifier (optional)

# ===== Phase 47: Optimistic Retry + Edge Consistency =====

# Optimistic Lock Retry Settings
# Enables retry with exponential backoff on version conflicts
OPTIMISTIC_RETRY_ENABLED=true           # Enable optimistic locking (default: true)
OPTIMISTIC_RETRY_MAX_ATTEMPTS=5         # Max retry attempts (default: 5)
OPTIMISTIC_RETRY_BASE_DELAY_MS=10       # Initial delay in ms (default: 10)
OPTIMISTIC_RETRY_MAX_DELAY_MS=1000      # Max delay in ms (default: 1000)
OPTIMISTIC_RETRY_MULTIPLIER=2.0         # Backoff multiplier (default: 2.0)

# Edge Staleness Cascade Settings
# Controls how edge updates cascade when node embeddings change
EDGE_STALENESS_CASCADE_ENABLED=true     # Enable staleness cascade (default: true)
EDGE_STALENESS_REFRESH_BATCH_SIZE=100   # Edges to refresh per call (default: 100)
EDGE_STALENESS_RECLUSTER_THRESHOLD=0.3  # Centroid drift for re-clustering (default: 0.3)
