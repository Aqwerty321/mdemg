{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Neo4j",
      "type": "shell",
      "command": "docker compose up -d",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Stop Neo4j",
      "type": "shell",
      "command": "docker compose down",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Apply Migrations",
      "type": "shell",
      "command": "for f in migrations/V*.cypher; do echo \"Applying $f\"; docker exec -i mdemg-neo4j cypher-shell -u neo4j -p testpassword < \"$f\"; done",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Run MDEMG Server",
      "type": "shell",
      "command": "go run ./cmd/server",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "NEO4J_URI": "bolt://localhost:7687",
          "NEO4J_USER": "neo4j",
          "NEO4J_PASS": "testpassword",
          "REQUIRED_SCHEMA_VERSION": "4",
          "LISTEN_ADDR": ":8082"
        }
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "isBackground": true
    },
    {
      "label": "Test Health Endpoint",
      "type": "shell",
      "command": "PORT=$(cat .mdemg.port 2>/dev/null || echo 9999); curl -s http://localhost:$PORT/healthz | jq",
      "problemMatcher": []
    },
    {
      "label": "Test Readiness Endpoint",
      "type": "shell",
      "command": "PORT=$(cat .mdemg.port 2>/dev/null || echo 9999); curl -s http://localhost:$PORT/readyz | jq",
      "problemMatcher": []
    },
    {
      "label": "Go Mod Tidy",
      "type": "shell",
      "command": "go mod tidy",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Go Build",
      "type": "shell",
      "command": "go build -o bin/server ./cmd/server",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$go"],
      "group": "build"
    },
    {
      "label": "Check Schema Version",
      "type": "shell",
      "command": "docker exec mdemg-neo4j cypher-shell -u neo4j -p testpassword \"MATCH (s:SchemaMeta {key:'schema'}) RETURN s.current_version\"",
      "problemMatcher": []
    }
  ]
}
