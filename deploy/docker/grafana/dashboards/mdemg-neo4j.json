{
  "annotations": {
    "list": []
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "MDEMG Overview",
      "url": "/d/mdemg-overview",
      "type": "link"
    }
  ],
  "panels": [
    {
      "title": "Total Nodes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "mdemg_neo4j_graph_total_nodes",
          "legendFormat": "nodes"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Total Edges",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "mdemg_neo4j_graph_total_edges",
          "legendFormat": "edges"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "purple", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Total Spaces",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "mdemg_neo4j_graph_total_spaces",
          "legendFormat": "spaces"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Neo4j Pool Active",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "mdemg_neo4j_pool_active_connections",
          "legendFormat": "active"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "title": "Heap Memory",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "mdemg_memory_heap_bytes",
          "legendFormat": "heap"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 536870912 },
              { "color": "red", "value": 1073741824 }
            ]
          }
        }
      }
    },
    {
      "title": "Open Circuits",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [
        {
          "expr": "count(mdemg_circuit_breaker_state == 1) or vector(0)",
          "legendFormat": "open"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Neo4j Container CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "mdemg_neo4j_container_cpu_percent",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "title": "Neo4j Container Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "mdemg_neo4j_container_mem_used_bytes",
          "legendFormat": "used"
        },
        {
          "expr": "mdemg_neo4j_container_mem_limit_bytes",
          "legendFormat": "limit"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0
        }
      }
    },
    {
      "title": "Space Overview",
      "description": "Per-space graph stats: nodes, edges, observations, orphans, learning edges, health score",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 11 },
      "targets": [
        {
          "expr": "mdemg_neo4j_graph_nodes",
          "legendFormat": "{{space_id}}",
          "instant": true,
          "format": "table",
          "refId": "A"
        },
        {
          "expr": "mdemg_neo4j_graph_edges",
          "legendFormat": "{{space_id}}",
          "instant": true,
          "format": "table",
          "refId": "B"
        },
        {
          "expr": "mdemg_neo4j_graph_observations",
          "legendFormat": "{{space_id}}",
          "instant": true,
          "format": "table",
          "refId": "C"
        },
        {
          "expr": "mdemg_neo4j_graph_orphans",
          "legendFormat": "{{space_id}}",
          "instant": true,
          "format": "table",
          "refId": "D"
        },
        {
          "expr": "mdemg_neo4j_graph_learning_edges",
          "legendFormat": "{{space_id}}",
          "instant": true,
          "format": "table",
          "refId": "E"
        },
        {
          "expr": "mdemg_neo4j_graph_health_score",
          "legendFormat": "{{space_id}}",
          "instant": true,
          "format": "table",
          "refId": "F"
        }
      ],
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": {
            "byField": "space_id"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "space_id" },
            "properties": [
              { "id": "displayName", "value": "Space" },
              { "id": "custom.width", "value": 180 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "displayName", "value": "Nodes" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #B" },
            "properties": [
              { "id": "displayName", "value": "Edges" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #C" },
            "properties": [
              { "id": "displayName", "value": "Observations" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #D" },
            "properties": [
              { "id": "displayName", "value": "Orphans" },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 10 },
                  { "color": "red", "value": 50 }
                ]
              }},
              { "id": "custom.displayMode", "value": "color-background-solid" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #E" },
            "properties": [
              { "id": "displayName", "value": "Learning Edges" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #F" },
            "properties": [
              { "id": "displayName", "value": "Health" },
              { "id": "unit", "value": "percentunit" },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "red", "value": null },
                  { "color": "yellow", "value": 0.5 },
                  { "color": "green", "value": 0.8 }
                ]
              }},
              { "id": "custom.displayMode", "value": "color-background-solid" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          }
        ]
      }
    },
    {
      "title": "Health Score Over Time",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 21 },
      "targets": [
        {
          "expr": "mdemg_neo4j_graph_health_score and on(space_id) (mdemg_neo4j_graph_nodes @ end())",
          "legendFormat": "{{space_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      }
    },
    {
      "title": "Orphans Per Space Over Time",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 21 },
      "targets": [
        {
          "expr": "mdemg_neo4j_graph_orphans and on(space_id) (mdemg_neo4j_graph_nodes @ end())",
          "legendFormat": "{{space_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "title": "Neo4j Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "mdemg_neo4j_pool_active_connections",
          "legendFormat": "active"
        },
        {
          "expr": "mdemg_neo4j_pool_idle_connections",
          "legendFormat": "idle"
        },
        {
          "expr": "mdemg_neo4j_pool_waiting_requests",
          "legendFormat": "waiting"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0
        }
      }
    },
    {
      "title": "Learning Edges Over Time",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "mdemg_neo4j_graph_learning_edges and on(space_id) (mdemg_neo4j_graph_nodes @ end())",
          "legendFormat": "{{space_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0
        }
      }
    }
  ],
  "schemaVersion": 30,
  "style": "dark",
  "tags": ["mdemg", "neo4j", "graph"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "MDEMG Neo4j Graph",
  "uid": "mdemg-neo4j",
  "version": 1
}
