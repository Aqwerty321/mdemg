{
  "uats_version": "1.0.0",
  "api": {
    "name": "Bulk Archive",
    "base_url": "http://localhost:8082",
    "version": "v1",
    "service": "mdemg",
    "tags": [
      "memory",
      "archive",
      "write"
    ]
  },
  "metadata": {
    "author": "reh3376",
    "created": "2026-01-29",
    "description": "Validates Bulk Archive endpoint",
    "test_type": "contract",
    "priority": "medium"
  },
  "config": {
    "timeout_ms": 15000
  },
  "variables": {
    "test_space": "demo"
  },
  "request": {
    "method": "POST",
    "path": "/v1/memory/archive/bulk",
    "body": {
