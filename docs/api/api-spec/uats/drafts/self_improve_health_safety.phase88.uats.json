{
  "uats_version": "1.0.0",
  "api": {
    "name": "Phase 88 - Self-Improve Health Safety Block",
    "base_url": "${MDEMG_BASE_URL}",
    "version": "v1",
    "service": "mdemg",
    "tags": [
      "rsic",
      "phase88",
      "safety",
      "health"
    ]
  },
  "metadata": {
    "author": "reh3376",
    "created": "2026-02-16",
    "description": "Validates GET /v1/self-improve/health includes safety enforcement block with bounds, rollback state, and version.",
    "test_type": "contract",
    "priority": "high"
  },
  "config": {
    "timeout_ms": 5000
  },
  "request": {
    "method": "GET",
    "path": "/v1/self-improve/health"
  },
  "expected": {
    "status": 200,
    "body_assertions": [
      {
        "path": "$.status",
        "equals": "ok"
      },
      {
        "path": "$.safety.enforcement_active",
        "equals": true
      },
      {
        "path": "$.safety.safety_version",
        "equals": "phase88-v1"
      },
      {
        "path": "$.safety.bounds.max_nodes_affected",
        "type": "number"
      },
      {
        "path": "$.safety.bounds.max_edges_affected",
        "type": "number"
      },
      {
        "path": "$.safety.bounds.protected_spaces",
        "type": "array"
      },
      {
        "path": "$.safety.rollback.window_sec",
        "type": "number"
      },
      {
        "path": "$.safety.rollback.snapshots_held",
        "type": "number"
      }
    ]
  }
}
