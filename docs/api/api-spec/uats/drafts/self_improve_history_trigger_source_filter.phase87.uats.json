{
  "uats_version": "1.0.0",
  "api": {
    "name": "Phase 87 - Self-Improve History Trigger Source Filter",
    "base_url": "${MDEMG_BASE_URL}",
    "version": "v1",
    "service": "mdemg",
    "tags": [
      "rsic",
      "phase87",
      "history",
      "filtering"
    ]
  },
  "metadata": {
    "author": "reh3376",
    "created": "2026-01-22",
    "description": "Validates trigger-source filtering contract for GET /v1/self-improve/history (Phase 87 design draft).",
    "test_type": "contract-draft",
    "priority": "medium"
  },
  "config": {
    "timeout_ms": 10000,
    "sha256": "4c401907a2262e302da7a87fdcf6550a6ccf7d2801e61a1606c35b73b49287c1"
  },
  "request": {
    "method": "GET",
    "path": "/v1/self-improve/history",
    "query": {
      "space_id": "uats-rsic-phase87",
      "tier": "meso",
      "trigger_source": "manual_api",
      "limit": "5"
    }
  },
  "expected": {
    "status": 200,
    "body_assertions": [
      {
        "path": "$.history",
        "type": "array"
      },
      {
        "path": "$.count",
        "type": "integer"
      },
      {
        "path": "$.filters",
        "type": "object"
      },
      {
        "path": "$.filters.space_id",
        "equals": "uats-rsic-phase87"
      },
      {
        "path": "$.filters.tier",
        "equals": "meso"
      },
      {
        "path": "$.filters.trigger_source",
        "equals": "manual_api"
      }
    ]
  }
}
