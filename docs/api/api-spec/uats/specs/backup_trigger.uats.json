{
  "uats_version": "1.0.0",
  "api": {
    "name": "Trigger Backup",
    "base_url": "${MDEMG_BASE_URL}",
    "version": "v1",
    "service": "mdemg",
    "tags": [
      "backup",
      "trigger",
      "write"
    ]
  },
  "metadata": {
    "author": "reh3376",
    "created": "2026-02-07",
    "description": "Validates POST /v1/backup/trigger accepts partial backup request",
    "test_type": "contract",
    "priority": "high"
  },
  "config": {
    "timeout_ms": 15000,
    "sha256": "9b6d416868f0249f732af22983da702b3204fa5819763794be6af28044e21a51"
  },
  "variables": {},
  "request": {
    "method": "POST",
    "path": "/v1/backup/trigger",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "type": "partial_space",
      "space_ids": [
        "uats-backup-test"
      ],
      "label": "uats-test"
    }
  },
  "expected": {
    "status": 202,
    "body_assertions": [
      {
        "path": "$.backup_id",
        "type": "string"
      },
      {
        "path": "$.status",
        "operator": "equals",
        "value": "pending"
      }
    ]
  },
  "variants": [
    {
      "name": "missing_type",
      "description": "Trigger with missing type returns 400",
      "request": {
        "body": {
          "type": "",
          "space_ids": []
        }
      },
      "expected": {
        "status": 400,
        "body_assertions": [
          {
            "path": "$.error",
            "type": "string"
          }
        ]
      }
    }
  ]
}
