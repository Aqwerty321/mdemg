{
  "uats_version": "1.0.0",
  "api": {
    "name": "Cache Clear",
    "base_url": "${MDEMG_BASE_URL}",
    "version": "v1",
    "service": "mdemg",
    "tags": [
      "memory",
      "cache",
      "admin",
      "destructive"
    ]
  },
  "metadata": {
    "author": "reh3376",
    "created": "2026-02-06",
    "description": "Validates Cache Clear endpoint for clearing query cache entries",
    "test_type": "contract",
    "priority": "medium"
  },
  "config": {
    "timeout_ms": 15000,
    "sha256": "2de292e22de521127fc70f6fd3d8684d5077c17c40127b56894e7295f5483291"
  },
  "variables": {
    "test_space": "demo"
  },
  "request": {
    "method": "DELETE",
    "path": "/v1/memory/cache"
  },
  "expected": {
    "status": 400,
    "body_assertions": [
      {
        "path": "$.error",
        "equals": "confirmation required"
      },
      {
        "path": "$.message",
        "contains": "confirm=true"
      }
    ]
  },
  "variants": [
    {
      "name": "cache_clear_all",
      "description": "Clear all cache entries with confirmation",
      "request": {
        "method": "DELETE",
        "path": "/v1/memory/cache?confirm=true"
      },
      "expected": {
        "status": 200,
        "body_assertions": [
          {
            "path": "$.message",
            "equals": "All cache entries cleared"
          },
          {
            "path": "$.entries_cleared",
            "exists": true
          }
        ]
      }
    },
    {
      "name": "cache_clear_by_space",
      "description": "Clear cache entries for a specific space",
      "request": {
        "method": "DELETE",
        "path": "/v1/memory/cache?confirm=true&space_id=${test_space}"
      },
      "expected": {
        "status": 200,
        "body_assertions": [
          {
            "path": "$.message",
            "equals": "Cache cleared for space"
          },
          {
            "path": "$.space_id",
            "equals": "${test_space}"
          },
          {
            "path": "$.entries_cleared",
            "exists": true
          }
        ]
      }
    },
    {
      "name": "cache_clear_method_not_allowed",
      "description": "Non-DELETE methods are rejected",
      "request": {
        "method": "GET",
        "path": "/v1/memory/cache?confirm=true"
      },
      "expected": {
        "status": 405
      }
    }
  ]
}
