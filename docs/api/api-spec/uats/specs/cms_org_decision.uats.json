{
  "uats_version": "1.0.0",
  "api": {
    "name": "Process Org Review Decision",
    "base_url": "${MDEMG_BASE_URL}",
    "version": "v1",
    "service": "mdemg",
    "tags": [
      "conversation",
      "org-review",
      "write",
      "phase60"
    ]
  },
  "metadata": {
    "author": "claude",
    "created": "2026-02-07",
    "description": "Validates Org Review Decision endpoint for CMS Phase 60",
    "test_type": "contract",
    "priority": "high"
  },
  "config": {
    "timeout_ms": 5000,
    "sha256": "64cc8cfeedd4472fe78cb08135e3e59aced9de13a539aa8eda33b6d760a46c54"
  },
  "variables": {
    "test_space": "uats-orgreview-test",
    "test_obs_id": "uats-obs-to-review"
  },
  "request": {
    "method": "POST",
    "path": "/v1/conversation/org-reviews/{{test_obs_id}}/decision",
    "body": {
      "space_id": "{{test_space}}",
      "decision": "approve",
      "visibility": "team",
      "notes": "Approved by UATS test"
    },
    "headers": {
      "Content-Type": "application/json",
      "X-User-ID": "uats-test-reviewer"
    }
  },
  "expected": {
    "status": [
      200,
      404
    ],
    "body_assertions": []
  }
}
