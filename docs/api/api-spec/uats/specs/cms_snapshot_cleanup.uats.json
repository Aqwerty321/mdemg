{
  "uats_version": "1.0.0",
  "api": {
    "name": "Cleanup Old Snapshots",
    "base_url": "${MDEMG_BASE_URL}",
    "version": "v1",
    "service": "mdemg",
    "tags": [
      "conversation",
      "snapshot",
      "write",
      "phase60"
    ]
  },
  "metadata": {
    "author": "claude",
    "created": "2026-02-07",
    "description": "Validates Snapshot Cleanup endpoint for CMS Phase 60",
    "test_type": "contract",
    "priority": "low"
  },
  "config": {
    "timeout_ms": 10000,
    "sha256": "4da197bfc74fcabc0e3a101785d4a91cabba464ebfe4ab0005caff944a73c735"
  },
  "variables": {
    "test_space": "uats-snapshot-test"
  },
  "request": {
    "method": "POST",
    "path": "/v1/conversation/snapshot/cleanup",
    "body": {
      "space_id": "{{test_space}}",
      "retention_days": 30
    },
    "headers": {
      "Content-Type": "application/json"
    }
  },
  "expected": {
    "status": 200,
    "body_assertions": [
      {
        "path": "$.deleted",
        "type": "number"
      },
      {
        "path": "$.retention_days",
        "type": "number"
      }
    ]
  }
}
