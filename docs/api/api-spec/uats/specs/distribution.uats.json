{
  "uats_version": "1.0.0",
  "api": {
    "name": "Distribution Stats",
    "base_url": "${MDEMG_BASE_URL}",
    "version": "v1",
    "service": "mdemg",
    "tags": [
      "memory",
      "stats",
      "read"
    ]
  },
  "metadata": {
    "author": "reh3376",
    "created": "2026-01-29",
    "description": "Validates Distribution Stats endpoint",
    "test_type": "contract",
    "priority": "medium"
  },
  "config": {
    "timeout_ms": 15000,
    "sha256": "af7f2d9a0560512f48280ae666d8d9bb8a7882c9367c41e859c04b701a8aa5cb"
  },
  "variables": {
    "test_space": "demo"
  },
  "request": {
    "method": "GET",
    "path": "/v1/memory/distribution",
    "query": {
      "space_id": "{{test_space}}"
    }
  },
  "expected": {
    "status": 200,
    "body_assertions": [
      {
        "path": "$.stats.space_id",
        "type": "string"
      },
      {
        "path": "$.stats.edge_count",
        "type": "number"
      },
      {
        "path": "$.stats.phase",
        "type": "string"
      },
      {
        "path": "$.stats.phase_thresholds",
        "type": "object"
      },
      {
        "path": "$.history",
        "type": "array"
      }
    ]
  }
}
