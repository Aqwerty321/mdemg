{
  "uats_version": "1.0.0",
  "api": {
    "name": "Distribution Stats",
    "base_url": "${MDEMG_BASE_URL}",
    "version": "v1",
    "service": "mdemg",
    "tags": [
      "memory",
      "stats",
      "read"
    ]
  },
  "metadata": {
    "author": "reh3376",
    "created": "2026-01-29",
    "description": "Validates Distribution Stats endpoint",
    "test_type": "contract",
    "priority": "medium"
  },
  "config": {
    "timeout_ms": 15000,
    "sha256": "59cccf73614ad18187003e1829c8c3b46a666e1524cc2bcb5817ee5203aa8306"
  },
  "variables": {
    "test_space": "demo"
  },
  "request": {
    "method": "GET",
    "path": "/v1/memory/distribution",
    "query": {
      "space_id": "{{test_space}}"
    }
  },
  "expected": {
    "status": 200,
    "body_assertions": [
      {
        "path": "$.space_id",
        "type": "string"
      },
      {
        "path": "$.edge_count",
        "type": "number"
      },
      {
        "path": "$.phase",
        "type": "string"
      },
      {
        "path": "$.phase_thresholds",
        "type": "object"
      }
    ]
  }
}
