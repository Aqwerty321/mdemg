    "tags": [
      "system",
      "feedback",
      "write"
    ]
  },
  "metadata": {
    "author": "reh3376",
    "created": "2026-01-29",
    "description": "Validates Submit Feedback endpoint",
    "test_type": "contract",
    "priority": "medium"
  },
  "config": {
    "timeout_ms": 15000,
    "sha256": "895cd41b281012c620b7c33ce7d57e2a0428325347f80a918f000aa9b0db74af"
  },
  "variables": {
    "test_space": "demo"
  },
