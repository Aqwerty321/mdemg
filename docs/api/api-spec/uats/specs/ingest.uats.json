{
  "uats_version": "1.0.0",
  "api": {
    "name": "Ingest Memory",
    "base_url": "${MDEMG_BASE_URL}",
    "version": "v1",
    "service": "mdemg",
    "tags": [
      "memory",
      "ingest",
      "write"
    ]
  },
  "metadata": {
    "author": "reh3376",
    "created": "2026-01-29",
    "description": "Validates Ingest Memory endpoint",
    "test_type": "contract",
    "priority": "medium"
  },
  "config": {
    "timeout_ms": 15000,
    "sha256": "be9d7c8eb58eebec060c2984ca76a853535813d5ac31909172b26c498da1b667"
  },
  "variables": {
    "unique_id": {
      "generator": "timestamp_ms"
    },
    "test_space": "uats-ingest"
  },
  "request": {
    "method": "POST",
    "path": "/v1/memory/ingest",
    "body": {
      "space_id": "{{test_space}}-{{unique_id}}",
      "timestamp": "2026-01-29T00:00:00Z",
      "source": "uats-runner",
      "content": "Test content for UATS validation"
    },
    "headers": {
      "Content-Type": "application/json"
    }
  },
  "expected": {
    "status": 200,
    "body_assertions": [
      {
        "path": "$.node_id",
        "type": "string"
      },
      {
        "path": "$.space_id",
        "type": "string",
        "contains": "uats-ingest"
      },
      {
        "path": "$.obs_id",
        "type": "string"
      },
      {
        "path": "$.embedding_dims",
        "type": "integer"
      }
    ]
  },
  "variants": [
    {
      "name": "missing_content",
      "description": "Test validation error when content is missing",
      "request": {
        "body": {
          "space_id": "{{test_space}}",
          "source": "test",
          "content": null
        }
      },
      "expected": {
        "status": 400,
        "body_assertions": [
          {
            "path": "$.error",
            "type": "string"
          }
        ]
      }
    },
    {
      "name": "missing_source",
      "description": "Test validation error when source is missing",
      "request": {
        "body": {
          "space_id": "{{test_space}}",
          "content": "test",
          "source": null
        }
      },
      "expected": {
        "status": 400,
        "body_assertions": [
          {
            "path": "$.error",
            "type": "string"
          }
        ]
      }
    },
    {
      "name": "unix_timestamp_format",
      "description": "Ingest with unix seconds timestamp format",
      "request": {
        "body": {
          "space_id": "{{test_space}}-{{unique_id}}",
          "timestamp": "1739054400",
          "timestamp_format": "unix",
          "source": "uats-runner",
          "content": "Test unix timestamp format"
        }
      },
      "expected": {
        "status": 200,
        "body_assertions": [
          {
            "path": "$.node_id",
            "type": "string"
          },
          {
            "path": "$.obs_id",
            "type": "string"
          }
        ]
      }
    },
    {
      "name": "date_only_timestamp_format",
      "description": "Ingest with date-only timestamp format",
      "request": {
        "body": {
          "space_id": "{{test_space}}-{{unique_id}}",
          "timestamp": "2026-02-09",
          "timestamp_format": "date_only",
          "source": "uats-runner",
          "content": "Test date_only timestamp format"
        }
      },
      "expected": {
        "status": 200,
        "body_assertions": [
          {
            "path": "$.node_id",
            "type": "string"
          },
          {
            "path": "$.obs_id",
            "type": "string"
          }
        ]
      }
    },
    {
      "name": "invalid_timestamp_format",
      "description": "Reject invalid timestamp_format enum value",
      "request": {
        "body": {
          "space_id": "{{test_space}}",
          "timestamp": "2026-02-09T10:30:00Z",
          "timestamp_format": "epoch_ns",
          "source": "uats-runner",
          "content": "Should be rejected"
        }
      },
      "expected": {
        "status": 400,
        "body_assertions": [
          {
            "path": "$.error",
            "type": "string"
          }
        ]
      }
    }
  ]
}
