{
  "uats_version": "1.0.0",
  "api": {
    "name": "Ingest Codebase",
    "base_url": "${MDEMG_BASE_URL}",
    "version": "v1",
    "service": "mdemg",
    "operation_id": "ingestCodebase",
    "tags": [
      "memory",
      "ingest",
      "codebase",
      "jobs",
      "async"
    ]
  },
  "metadata": {
    "author": "reh3376",
    "created": "2026-01-29",
    "description": "Triggers codebase ingestion as a background job. Most complex MDEMG endpoint with nested config for languages, symbols, exclusions, processing, LLM summaries, and retry logic.",
    "test_type": "contract",
    "priority": "critical",
    "status": "active"
  },
  "config": {
    "timeout_ms": 30000,
    "response_time_max_ms": 5000,
    "ignore_fields": [
      "$.job_id",
      "$.stats.duration",
      "$.stats.rate"
    ],
    "sha256": "3be1142c80172b68617a61fee713694b00662ebdc4eb93f05c716dc836ec1f66"
  },
  "variables": {
    "test_space": "uats-ingest-test",
    "test_path": "/tmp/uats-test-codebase",
    "job_id": ""
  },
  "request": {
    "method": "POST",
    "path": "/v1/memory/ingest-codebase",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "space_id": "{{test_space}}",
      "path": "{{test_path}}"
    }
  },
  "expected": {
    "status": [
      200,
      202
    ],
    "headers": {
      "Content-Type": {
        "contains": "application/json"
      }
    },
    "body_assertions": [
      {
        "name": "job_id returned",
        "path": "$.job_id",
        "type": "string",
        "exists": true,
        "capture_as": "job_id"
      },
      {
        "name": "status is queued or running",
        "path": "$.status",
        "in": [
          "queued",
          "running"
        ]
      },
      {
        "name": "space_id echoed",
        "path": "$.space_id",
        "equals": "{{test_space}}"
      },
      {
        "name": "path echoed",
        "path": "$.path",
        "equals": "{{test_path}}"
      }
    ],
    "response_time": {
      "max_ms": 5000
    }
  },
  "captures": {
    "job_id": {
      "from": "body",
      "path": "$.job_id"
    }
  },
  "variants": [
    {
      "name": "full_config",
      "description": "Request with all configuration options",
      "request": {
        "body": {
          "space_id": "{{test_space}}",
          "path": "{{test_path}}",
          "source": {
            "type": "local",
            "branch": "main",
            "since": "HEAD~1"
          },
          "languages": {
            "typescript": true,
            "python": true,
            "java": false,
            "rust": true,
            "go": true,
            "markdown": true,
            "include_tests": false
          },
          "symbols": {
            "extract": true,
            "max_per_file": 500
          },
          "exclusions": {
            "preset": "default",
            "directories": [
              ".git",
              "vendor",
              "node_modules"
            ],
            "max_file_size": 1048576
          },
          "processing": {
            "batch_size": 100,
            "workers": 4,
            "max_elements_per_file": 500,
            "delay_ms": 50
          },
          "llm_summary": {
            "enabled": false,
            "provider": "openai",
            "model": "gpt-4o-mini",
            "batch_size": 10
          },
          "options": {
            "incremental": false,
            "archive_deleted": true,
            "consolidate": true,
            "dry_run": false,
            "verbose": false,
            "limit": 0
          },
          "retry": {
            "max_attempts": 3,
            "initial_delay_ms": 2000,
            "timeout_seconds": 300
          }
        }
      },
      "expected": {
        "status": [
          200,
          202
        ],
        "body_assertions": [
          {
            "path": "$.job_id",
            "type": "string",
            "exists": true
          },
          {
            "path": "$.status",
            "in": [
              "queued",
              "running"
            ]
          }
        ]
      }
    },
    {
      "name": "typescript_only",
      "description": "TypeScript project configuration",
      "request": {
        "body": {
          "space_id": "{{test_space}}",
          "path": "{{test_path}}",
          "languages": {
            "typescript": true,
            "python": false,
            "java": false,
            "rust": false,
            "go": false,
            "markdown": true
          },
          "processing": {
            "workers": 8
          }
        }
      },
      "expected": {
        "status": [
          200,
          202
        ]
      }
    },
    {
      "name": "ml_cuda_preset",
      "description": "ML/CUDA project with preset exclusions",
      "request": {
        "body": {
          "space_id": "{{test_space}}",
          "path": "{{test_path}}",
          "exclusions": {
            "preset": "ml_cuda"
          },
          "symbols": {
            "extract": true,
            "max_per_file": 500
          }
        }
      },
      "expected": {
        "status": [
          200,
          202
        ]
      }
    },
    {
      "name": "web_monorepo_preset",
      "description": "Web monorepo with preset exclusions",
      "request": {
        "body": {
          "space_id": "{{test_space}}",
          "path": "{{test_path}}",
          "exclusions": {
            "preset": "web_monorepo"
          }
        }
      },
      "expected": {
        "status": [
          200,
          202
        ]
      }
    },
    {
      "name": "incremental_update",
      "description": "Incremental ingestion since last commit",
      "request": {
        "body": {
          "space_id": "{{test_space}}",
          "path": "{{test_path}}",
          "options": {
            "incremental": true
          },
          "source": {
            "since": "HEAD~5"
          }
        }
      },
      "expected": {
        "status": [
          200,
          202
        ]
      }
    },
    {
      "name": "with_llm_summaries",
      "description": "Ingestion with LLM-generated summaries",
      "request": {
        "body": {
          "space_id": "{{test_space}}",
          "path": "{{test_path}}",
          "llm_summary": {
            "enabled": true,
            "provider": "openai",
            "model": "gpt-4o-mini",
            "batch_size": 10
          }
        }
      },
      "expected": {
        "status": [
          200,
          202
        ]
      }
    },
    {
      "name": "dry_run",
      "description": "Preview mode without actual ingestion",
      "request": {
        "body": {
          "space_id": "{{test_space}}",
          "path": "{{test_path}}",
          "options": {
            "dry_run": true,
            "verbose": true,
            "limit": 100
          }
        }
      },
      "expected": {
        "status": [
          200,
          202
        ],
        "body_assertions": [
          {
            "path": "$.status",
            "in": [
              "queued",
              "running",
              "completed"
            ]
          }
        ]
      }
    },
    {
      "name": "git_source",
      "description": "Git source type with branch",
      "request": {
        "body": {
          "space_id": "{{test_space}}",
          "path": "{{test_path}}",
          "source": {
            "type": "git",
            "branch": "develop",
            "since": "HEAD~10"
          }
        }
      },
      "expected": {
        "status": [
          200,
          202
        ]
      }
    },
    {
      "name": "high_performance",
      "description": "High performance settings for large codebase",
      "request": {
        "body": {
          "space_id": "{{test_space}}",
          "path": "{{test_path}}",
          "processing": {
            "batch_size": 200,
            "workers": 12,
            "max_elements_per_file": 1000,
            "delay_ms": 25
          },
          "retry": {
            "max_attempts": 5,
            "initial_delay_ms": 1000,
            "timeout_seconds": 600
          }
        }
      },
      "expected": {
        "status": [
          200,
          202
        ]
      }
    },
    {
      "name": "include_tests",
      "description": "Include test files in ingestion",
      "request": {
        "body": {
          "space_id": "{{test_space}}",
          "path": "{{test_path}}",
          "languages": {
            "typescript": true,
            "python": true,
            "go": true,
            "include_tests": true
          }
        }
      },
      "expected": {
        "status": [
          200,
          202
        ]
      }
    },
    {
      "name": "missing_space_id",
      "description": "Empty space_id is rejected with 400",
      "request": {
        "body": {
          "space_id": "",
          "path": "{{test_path}}"
        }
      },
      "expected": {
        "status": 400,
        "body_assertions": [
          {
            "path": "$.error",
            "contains": "space_id"
          }
        ]
      }
    },
    {
      "name": "missing_path",
      "description": "Empty path is rejected with 400",
      "request": {
        "body": {
          "space_id": "{{test_space}}",
          "path": ""
        }
      },
      "expected": {
        "status": 400,
        "body_assertions": [
          {
            "path": "$.error",
            "contains": "path"
          }
        ]
      }
    },
    {
      "name": "invalid_path",
      "description": "Path existence is validated upfront",
      "request": {
        "body": {
          "space_id": "{{test_space}}",
          "path": "/nonexistent/path/that/does/not/exist"
        }
      },
      "expected": {
        "status": 400,
        "body_assertions": [
          {
            "path": "$.error",
            "contains": "path"
          }
        ]
      }
    },
    {
      "name": "invalid_preset",
      "description": "Jobs are queued even with invalid preset (validation in job)",
      "request": {
        "body": {
          "space_id": "{{test_space}}",
          "path": "{{test_path}}",
          "exclusions": {
            "preset": "invalid_preset_name"
          }
        }
      },
      "expected": {
        "status": [
          200,
          202
        ],
        "body_assertions": [
          {
            "path": "$.job_id",
            "exists": true
          }
        ]
      }
    },
    {
      "name": "invalid_source_type",
      "description": "Jobs are queued even with invalid source type",
      "request": {
        "body": {
          "space_id": "{{test_space}}",
          "path": "{{test_path}}",
          "source": {
            "type": "invalid"
          }
        }
      },
      "expected": {
        "status": [
          200,
          202
        ],
        "body_assertions": [
          {
            "path": "$.job_id",
            "exists": true
          }
        ]
      }
    },
    {
      "name": "invalid_llm_provider",
      "description": "Jobs are queued even with invalid LLM provider",
      "request": {
        "body": {
          "space_id": "{{test_space}}",
          "path": "{{test_path}}",
          "llm_summary": {
            "enabled": true,
            "provider": "invalid_provider"
          }
        }
      },
      "expected": {
        "status": [
          200,
          202
        ],
        "body_assertions": [
          {
            "path": "$.job_id",
            "exists": true
          }
        ]
      }
    },
    {
      "name": "negative_workers",
      "description": "Jobs are queued even with negative workers",
      "request": {
        "body": {
          "space_id": "{{test_space}}",
          "path": "{{test_path}}",
          "processing": {
            "workers": -1
          }
        }
      },
      "expected": {
        "status": [
          200,
          202
        ],
        "body_assertions": [
          {
            "path": "$.job_id",
            "exists": true
          }
        ]
      }
    },
    {
      "name": "get_returns_job_list",
      "description": "GET returns the list of jobs (same as ingest_codebase_list)",
      "request": {
        "method": "GET",
        "path": "/v1/memory/ingest-codebase",
        "body": null
      },
      "expected": {
        "status": 200,
        "body_assertions": [
          {
            "path": "$.jobs",
            "type": "array",
            "exists": true
          }
        ]
      }
    }
  ]
}
