{
  "uats_version": "1.0.0",
  "api": {
    "name": "List Ingest Codebase Jobs",
    "base_url": "http://localhost:8082",
    "version": "v1",
    "service": "mdemg",
    "operation_id": "listIngestCodebaseJobs",
    "tags": [
      "memory",
      "ingest",
      "codebase",
      "jobs",
      "read"
    ]
  },
  "metadata": {
    "author": "reh3376",
    "created": "2026-01-29",
    "description": "List all ingest-codebase jobs with their status",
    "test_type": "contract",
    "priority": "medium",
    "status": "active"
  },
  "config": {
    "timeout_ms": 5000,
    "sha256": "47be90bae80ae42fadc8afc17149526d144e120cc2067ed009d7d54487d5e6e4"
  },
  "request": {
    "method": "GET",
    "path": "/v1/memory/ingest-codebase"
  },
  "expected": {
    "status": 200,
    "headers": {
      "Content-Type": {
        "contains": "application/json"
      }
    },
    "body_assertions": [
      {
        "name": "jobs array exists",
        "path": "$.jobs",
        "type": "array",
        "exists": true
      }
    ]
  },
  "variants": [
    {
      "name": "with_space_filter",
      "description": "Filter jobs by space_id",
      "request": {
        "query": {
          "space_id": "demo"
        }
      },
      "expected": {
        "status": 200,
        "body_assertions": [
          {
            "path": "$.jobs",
            "type": "array"
          }
        ]
      }
    },
    {
      "name": "with_status_filter",
      "description": "Filter jobs by status",
      "request": {
        "query": {
          "status": "running"
        }
      },
      "expected": {
        "status": 200,
        "body_assertions": [
          {
            "path": "$.jobs",
            "type": "array"
          }
        ]
      }
    }
  ]
}
