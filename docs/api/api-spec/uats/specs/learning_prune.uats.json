  },
  "expected": {
    "status": 200,
    "body_assertions": [
      {
        "path": "$.space_id",
        "type": "string"
      },
      {
        "path": "$.decayed_deleted",
        "type": "integer"
      },
      {
        "path": "$.excess_deleted",
        "type": "integer"
      },
      {
        "path": "$.total_deleted",
        "type": "integer"
      }
    ]
  }
