      "write"
    ]
  },
  "metadata": {
    "author": "reh3376",
    "created": "2026-01-29",
    "description": "Validates Prune Learning Edges endpoint",
    "test_type": "contract",
    "priority": "medium"
  },
  "config": {
    "timeout_ms": 15000,
    "sha256": "1ab86e4726b6574bf870460bd7bcda0d85ce48f35b90d661d5fcd7ea6b801d3a"
  },
  "variables": {
    "test_space": "uats-prune-test"
