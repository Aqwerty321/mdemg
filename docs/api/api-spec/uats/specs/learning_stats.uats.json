{
  "uats_version": "1.0.0",
  "api": {
    "name": "Learning Stats",
    "base_url": "${MDEMG_BASE_URL}",
    "version": "v1",
    "service": "mdemg",
    "tags": [
      "learning",
      "stats",
      "read"
    ]
  },
  "metadata": {
    "author": "reh3376",
    "created": "2026-01-29",
    "description": "Validates Learning Stats endpoint",
    "test_type": "contract",
    "priority": "medium"
  },
  "config": {
    "timeout_ms": 15000,
    "sha256": "e35d5c32caed1f45a585b22397e52e080d4fb3c7f42f1ae9628bbd06698de243"
  },
  "variables": {
    "test_space": "uats-learning-test"
  },
  "request": {
    "method": "GET",
    "path": "/v1/learning/stats",
    "query": {
      "space_id": "{{test_space}}"
    }
  },
  "expected": {
    "status": 200,
    "body_assertions": [
      {
        "path": "$.space_id",
        "type": "string"
      },
      {
        "path": "$.total_edges",
        "type": "integer"
      },
      {
        "path": "$.decay_per_day",
        "type": "number"
      },
      {
        "path": "$.prune_threshold",
        "type": "number"
      },
      {
        "path": "$.max_edges_per_node",
        "type": "integer"
      },
      {
        "path": "$.freeze_state",
        "type": "object"
      }
    ]
  }
}
