{
  "uats_version": "1.0.0",
  "api": {
    "name": "Plugin Create",
    "base_url": "${MDEMG_BASE_URL}",
    "version": "v1",
    "service": "mdemg",
    "tags": [
      "system",
      "plugins",
      "create"
    ]
  },
  "metadata": {
    "author": "claude",
    "created": "2026-02-06",
    "description": "Validates POST /v1/plugins/create endpoint for scaffold generation",
    "test_type": "contract",
    "priority": "high"
  },
  "config": {
    "timeout_ms": 30000
  },
  "test_cases": [
    {
      "id": "plugin_create_ingestion",
      "name": "Create INGESTION plugin scaffold",
      "request": {
        "method": "POST",
        "path": "/v1/plugins/create",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "name": "Test Ingestion Plugin",
          "type": "INGESTION",
          "version": "1.0.0",
          "description": "E2E test plugin"
        }
      },
      "expected": {
        "status": 201,
        "body_assertions": [
          {
            "path": "$.data.plugin_id",
            "operator": "equals",
            "value": "test-ingestion-plugin"
          },
          {
            "path": "$.data.files_created",
            "type": "array"
          },
          {
            "path": "$.data.files_created[?(@=='manifest.json')]",
            "operator": "exists"
          },
          {
            "path": "$.data.files_created[?(@=='main.go')]",
            "operator": "exists"
          },
          {
            "path": "$.data.files_created[?(@=='handler.go')]",
            "operator": "exists"
          },
          {
            "path": "$.data.validation.manifest_valid",
            "operator": "equals",
            "value": true
          }
        ]
      }
    },
    {
      "id": "plugin_create_reasoning",
      "name": "Create REASONING plugin scaffold",
      "request": {
        "method": "POST",
        "path": "/v1/plugins/create",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "name": "Test Reasoning Plugin",
          "type": "REASONING",
          "version": "1.0.0"
        }
      },
      "expected": {
        "status": 201,
        "body_assertions": [
          {
            "path": "$.data.plugin_id",
            "operator": "equals",
            "value": "test-reasoning-plugin"
          },
          {
            "path": "$.data.validation.manifest_valid",
            "operator": "equals",
            "value": true
          }
        ]
      }
    },
    {
      "id": "plugin_create_ape",
      "name": "Create APE plugin scaffold",
      "request": {
        "method": "POST",
        "path": "/v1/plugins/create",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "name": "Test APE Plugin",
          "type": "APE",
          "version": "1.0.0"
        }
      },
      "expected": {
        "status": 201,
        "body_assertions": [
          {
            "path": "$.data.plugin_id",
            "operator": "equals",
            "value": "test-ape-plugin"
          },
          {
            "path": "$.data.validation.manifest_valid",
            "operator": "equals",
            "value": true
          }
        ]
      }
    },
    {
      "id": "plugin_create_missing_name",
      "name": "Reject plugin creation without name",
      "request": {
        "method": "POST",
        "path": "/v1/plugins/create",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "type": "INGESTION"
        }
      },
      "expected": {
        "status": 400,
        "body_assertions": [
          {
            "path": "$.error",
            "operator": "contains",
            "value": "name"
          }
        ]
      }
    },
    {
      "id": "plugin_create_missing_type",
      "name": "Reject plugin creation without type",
      "request": {
        "method": "POST",
        "path": "/v1/plugins/create",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "name": "My Plugin"
        }
      },
      "expected": {
        "status": 400,
        "body_assertions": [
          {
            "path": "$.error",
            "operator": "contains",
            "value": "type"
          }
        ]
      }
    },
    {
      "id": "plugin_create_invalid_type",
      "name": "Reject plugin creation with invalid type",
      "request": {
        "method": "POST",
        "path": "/v1/plugins/create",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "name": "My Plugin",
          "type": "INVALID_TYPE"
        }
      },
      "expected": {
        "status": 400,
        "body_assertions": [
          {
            "path": "$.error",
            "operator": "contains",
            "value": "type"
          }
        ]
      }
    }
  ]
}
