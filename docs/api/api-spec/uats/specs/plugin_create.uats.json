{
  "uats_version": "1.0.0",
  "api": {
    "name": "Plugin Create",
    "base_url": "${MDEMG_BASE_URL}",
    "version": "v1",
    "service": "mdemg",
    "tags": [
      "system",
      "plugins",
      "create"
    ]
  },
  "metadata": {
    "author": "claude",
    "created": "2026-02-06",
    "description": "Validates POST /v1/plugins/create endpoint for scaffold generation",
    "test_type": "contract",
    "priority": "high"
  },
  "config": {
    "timeout_ms": 30000,
    "sha256": "481bf71ff2d80832f990c7e19c789a3236b1272b01895cb630073f92368ecf01"
  },
  "request": {
    "method": "POST",
    "path": "/v1/plugins/create",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Test Ingestion Plugin",
      "type": "INGESTION",
      "version": "1.0.0",
      "description": "E2E test plugin"
    }
  },
  "expected": {
    "status": 201,
    "body_assertions": [
      {
        "path": "$.data.plugin_id",
        "equals": "test-ingestion-plugin"
      },
      {
        "path": "$.data.files_created",
        "type": "array"
      },
      {
        "path": "$.data.files_created[?(@=='manifest.json')]",
        "exists": true
      },
      {
        "path": "$.data.files_created[?(@=='main.go')]",
        "exists": true
      },
      {
        "path": "$.data.files_created[?(@=='handler.go')]",
        "exists": true
      },
      {
        "path": "$.data.validation.manifest_valid",
        "type": "boolean"
      }
    ]
  },
  "variants": [
    {
      "name": "plugin_create_reasoning",
      "description": "Create REASONING plugin scaffold",
      "request": {
        "method": "POST",
        "path": "/v1/plugins/create",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "name": "Test Reasoning Plugin",
          "type": "REASONING",
          "version": "1.0.0"
        }
      },
      "expected": {
        "status": 201,
        "body_assertions": [
          {
            "path": "$.data.plugin_id",
            "equals": "test-reasoning-plugin"
          },
          {
            "path": "$.data.validation.manifest_valid",
            "type": "boolean"
          }
        ]
      }
    },
    {
      "name": "plugin_create_ape",
      "description": "Create APE plugin scaffold",
      "request": {
        "method": "POST",
        "path": "/v1/plugins/create",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "name": "Test APE Plugin",
          "type": "APE",
          "version": "1.0.0"
        }
      },
      "expected": {
        "status": 201,
        "body_assertions": [
          {
            "path": "$.data.plugin_id",
            "equals": "test-ape-plugin"
          },
          {
            "path": "$.data.validation.manifest_valid",
            "type": "boolean"
          }
        ]
      }
    },
    {
      "name": "plugin_create_missing_name",
      "description": "Reject plugin creation without name",
      "request": {
        "method": "POST",
        "path": "/v1/plugins/create",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "name": "",
          "type": "INGESTION"
        }
      },
      "expected": {
        "status": 400,
        "body_assertions": [
          {
            "path": "$.error",
            "contains": "name"
          }
        ]
      }
    },
    {
      "name": "plugin_create_missing_type",
      "description": "Reject plugin creation without type",
      "request": {
        "method": "POST",
        "path": "/v1/plugins/create",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "name": "My Plugin",
          "type": ""
        }
      },
      "expected": {
        "status": 400,
        "body_assertions": [
          {
            "path": "$.error",
            "contains": "type"
          }
        ]
      }
    },
    {
      "name": "plugin_create_invalid_type",
      "description": "Reject plugin creation with invalid type",
      "request": {
        "method": "POST",
        "path": "/v1/plugins/create",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "name": "My Plugin",
          "type": "INVALID_TYPE"
        }
      },
      "expected": {
        "status": 400,
        "body_assertions": [
          {
            "path": "$.error",
            "contains": "type"
          }
        ]
      }
    }
  ]
}
