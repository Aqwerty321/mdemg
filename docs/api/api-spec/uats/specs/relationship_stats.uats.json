{
  "uats_version": "1.0.0",
  "api": {
    "name": "Relationship Stats",
    "base_url": "${MDEMG_BASE_URL}",
    "version": "v1",
    "service": "mdemg",
    "tags": [
      "symbols",
      "relationships",
      "read"
    ]
  },
  "metadata": {
    "author": "reh3376",
    "created": "2026-02-08",
    "description": "Validates Symbol Relationship Stats endpoint",
    "test_type": "contract",
    "priority": "medium"
  },
  "config": {
    "timeout_ms": 15000,
    "sha256": "07fbc00df253b780ed2a4d55fbc1d502196959eae5d375728f23315968d408a8"
  },
  "variables": {
    "test_space": "demo"
  },
  "request": {
    "method": "GET",
    "path": "/v1/symbols/relationships",
    "query": {
      "space_id": "{{test_space}}"
    }
  },
  "expected": {
    "status": 200,
    "body_assertions": [
      {
        "path": "$.space_id",
        "type": "string"
      },
      {
        "path": "$.counts",
        "type": "object"
      }
    ]
  },
  "variants": [
    {
      "name": "missing_space_id",
      "description": "Test validation error when space_id is missing",
      "request": {
        "query": {
          "space_id": null
        }
      },
      "expected": {
        "status": 400,
        "body_assertions": [
          {
            "path": "$.error",
            "type": "string"
          }
        ]
      }
    }
  ]
}
