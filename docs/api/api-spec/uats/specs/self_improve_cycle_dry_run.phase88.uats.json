{
  "uats_version": "1.0.0",
  "api": {
    "name": "Phase 88 - Self-Improve Cycle Dry Run",
    "base_url": "${MDEMG_BASE_URL}",
    "version": "v1",
    "service": "mdemg",
    "tags": [
      "rsic",
      "phase88",
      "safety",
      "dry-run"
    ]
  },
  "metadata": {
    "author": "reh3376",
    "created": "2026-02-16",
    "description": "Validates dry-run mode on POST /v1/self-improve/cycle returns safety_version and dry_run fields with zero mutations.",
    "test_type": "contract",
    "priority": "high"
  },
  "config": {
    "timeout_ms": 30000,
    "sha256": "a8ca357e163e6cee63db3da2e2f493f5b431ad518d8d7a6a43d622f259ef6316"
  },
  "variables": {
    "test_space": "uats-rsic-phase88-dryrun",
    "idempotency_key": {
      "generator": "uuid"
    }
  },
  "request": {
    "method": "POST",
    "path": "/v1/self-improve/cycle",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "space_id": "{{test_space}}",
      "tier": "meso",
      "dry_run": true,
      "idempotency_key": "{{idempotency_key}}"
    }
  },
  "expected": {
    "status": 200,
    "body_assertions": [
      {
        "path": "$.cycle_id",
        "type": "string"
      },
      {
        "path": "$.tier",
        "equals": "meso"
      },
      {
        "path": "$.dry_run",
        "equals": true
      },
      {
        "path": "$.safety_version",
        "equals": "phase88-v1"
      },
      {
        "path": "$.actions_executed",
        "equals": 0
      }
    ]
  }
}
