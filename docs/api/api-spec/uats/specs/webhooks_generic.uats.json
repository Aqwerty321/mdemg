{
  "uats_version": "1.0.0",
  "api": {
    "name": "Generic Webhooks",
    "base_url": "${MDEMG_BASE_URL}",
    "version": "v1",
    "service": "mdemg",
    "tags": [
      "webhooks",
      "integration",
      "write",
      "phase-9.4"
    ]
  },
  "metadata": {
    "author": "reh3376",
    "created": "2026-02-06",
    "description": "Validates generic webhook handler for GitHub, GitLab, Bitbucket, etc.",
    "test_type": "contract",
    "priority": "medium"
  },
  "config": {
    "timeout_ms": 30000,
    "sha256": "0c5ebad491a5c0e23085f2e6aaa8457083d87d623da1045b95361ee221555159"
  },
  "variables": {
    "webhook_source": "github"
  },
  "request": {
    "method": "POST",
    "path": "/v1/webhooks/${webhook_source}",
    "headers": {
      "Content-Type": "application/json",
      "X-GitHub-Event": "push",
      "X-Hub-Signature-256": "sha256=abc123"
    },
    "body": {
      "ref": "refs/heads/main",
      "head_commit": {
        "id": "abc123def456",
        "message": "Test commit",
        "url": "https://github.com/example/repo/commit/abc123"
      },
      "repository": {
        "full_name": "example/repo"
      }
    }
  },
  "expected": {
    "status": [
      200,
      404
    ],
    "body_assertions": [
      {
        "path": "$.status",
        "type": "string",
        "in": [
          "accepted",
          "ignored"
        ],
        "optional": true
      }
    ],
    "notes": "Returns 404 if source not configured, 200 with accepted/ignored status otherwise"
  },
  "error_cases": [
    {
      "name": "method_not_allowed",
      "request": {
        "method": "GET",
        "path": "/v1/webhooks/github"
      },
      "expected": {
        "status": 405
      }
    },
    {
      "name": "unconfigured_source",
      "request": {
        "method": "POST",
        "path": "/v1/webhooks/unknown-source",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "test": "data"
        }
      },
      "expected": {
        "status": 404,
        "body_assertions": [
          {
            "path": "$.error",
            "type": "string",
            "contains": "not configured"
          }
        ]
      }
    },
    {
      "name": "missing_signature_when_required",
      "request": {
        "method": "POST",
        "path": "/v1/webhooks/github",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "test": "data"
        }
      },
      "expected": {
        "status": [
          401,
          404
        ],
        "notes": "Returns 401 if signature required but missing, 404 if source not configured"
      }
    }
  ]
}
