{
  "uats_version": "1.0.0",
  "api": {
    "name": "Record Observation",
    "base_url": "${MDEMG_BASE_URL}",
    "version": "v1",
    "service": "mdemg",
    "tags": [
      "conversation",
      "observe",
      "write"
    ]
  },
  "metadata": {
    "author": "reh3376",
    "created": "2026-01-29",
    "description": "Validates Record Observation endpoint",
    "test_type": "contract",
    "priority": "medium"
  },
  "config": {
    "timeout_ms": 15000
  },
  "variables": {
    "test_space": "demo"
  },
  "request": {
    "method": "POST",
    "path": "/v1/conversation/observe",
    "body": {
      "space_id": "{{test_space}}",
      "session_id": "uats-session",
      "content": "Test observation from UATS"
    },
    "headers": {
      "Content-Type": "application/json"
    }
  },
  "expected": {
    "status": [
      200,
      201
    ],
    "body_assertions": [
      {
        "path": "$.observation_id",
        "type": "string"
      }
    ]
  }
}