{
  "uats_version": "1.0.0",
  "api": {
    "name": "Trigger Ingest Job",
    "base_url": "${MDEMG_BASE_URL}",
    "version": "v1",
    "service": "mdemg",
    "tags": [
      "ingest",
      "jobs",
      "write"
    ]
  },
  "metadata": {
    "author": "reh3376",
    "created": "2026-01-29",
    "description": "Validates Trigger Ingest Job endpoint",
    "test_type": "contract",
    "priority": "medium"
  },
  "config": {
    "timeout_ms": 15000
  },
  "variables": {
    "test_space": "demo"
  },
  "request": {
    "method": "POST",
    "path": "/v1/memory/ingest/trigger",
    "body": {
      "space_id": "{{test_space}}",
      "source_type": "directory",
      "source_path": "/tmp/test"
    },
    "headers": {
      "Content-Type": "application/json"
    }
  },
  "expected": {
    "status": [
      200,
      202
    ],
    "body_assertions": [
      {
        "path": "$.job_id",
        "type": "string"
      }
    ]
  }
}