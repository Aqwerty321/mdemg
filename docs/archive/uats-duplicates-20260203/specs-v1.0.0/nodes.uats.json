{
  "uats_version": "1.0.0",
  "api": {
    "name": "Node Operations",
    "base_url": "${MDEMG_BASE_URL}",
    "version": "v1",
    "service": "mdemg",
    "tags": ["memory", "nodes", "crud"]
  },
  "metadata": {
    "author": "reh3376",
    "created": "2026-01-29",
    "description": "CRUD operations on individual memory nodes",
    "test_type": "contract",
    "priority": "high"
  },
  "config": {
    "timeout_ms": 10000
  },
  "variables": {
    "test_space": "demo",
    "test_node_id": "test-node-uats"
  },
  "request": {
    "method": "GET",
    "path": "/v1/memory/nodes/{{test_node_id}}",
    "query": {
      "space_id": "{{test_space}}"
    }
  },
  "expected": {
    "status": [200, 404],
    "body_assertions": []
  },
  "variants": [
    {
      "name": "delete_node",
      "description": "Delete a node by ID",
      "request": {
        "method": "DELETE",
        "path": "/v1/memory/nodes/{{test_node_id}}",
        "query": {
          "space_id": "{{test_space}}"
        }
      },
      "expected": {
        "status": [200, 204, 404]
      }
    },
    {
      "name": "update_node",
      "description": "Update a node by ID",
      "request": {
        "method": "PATCH",
        "path": "/v1/memory/nodes/{{test_node_id}}",
        "headers": {"Content-Type": "application/json"},
        "body": {
          "space_id": "{{test_space}}",
          "name": "Updated Node Name"
        }
      },
      "expected": {
        "status": [200, 404]
      }
    }
  ]
}
