# INI/dotenv Parser Test Fixture
# Tests key-value extraction for config files
# Line numbers are predictable for UPTS validation

# === Pattern 1: Simple key-value (dotenv style) ===
# Line 7-12
APP_NAME=test-project
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=info
PORT=3000
HOST=localhost

# === Pattern: Quoted values ===
# Line 15-17
DATABASE_URL="postgres://user:pass@localhost:5432/db"
SECRET_KEY='super-secret-key-123'
API_ENDPOINT="https://api.example.com/v1"

# === Pattern: INI sections ===
# Line 20-26
[database]
host = localhost
port = 5432
name = testdb
user = admin
password = secret

# Line 28-32
[server]
host = 0.0.0.0
port = 8080
workers = 4
timeout = 30

# Line 34-38
[logging]
level = DEBUG
format = json
file = /var/log/app.log
rotate = daily

# === Pattern: Nested sections (INI) ===
# Line 41-45
[cache.redis]
host = localhost
port = 6379
db = 0
ttl = 3600

# === Pattern: Java properties style ===
# Line 48-53
spring.datasource.url=jdbc:postgresql://localhost:5432/db
spring.datasource.username=user
spring.datasource.password=pass
spring.jpa.hibernate.ddl-auto=update
server.port=8080
management.endpoints.web.exposure.include=health,info

# === Pattern: Boolean and numeric values ===
# Line 56-60
ENABLE_CACHE=true
ENABLE_METRICS=false
MAX_CONNECTIONS=100
RETRY_COUNT=3
TIMEOUT_MS=5000
