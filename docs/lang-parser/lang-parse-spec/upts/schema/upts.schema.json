{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mdemg.dev/schemas/upts/v1.0.0",
  "title": "Universal Parser Test Specification",
  "description": "Language-agnostic test specification for MDEMG language parsers",
  "type": "object",
  "required": ["upts_version", "language", "fixture", "expected"],
  
  "properties": {
    "upts_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "UPTS schema version"
    },
    
    "language": {
      "type": "string",
      "enum": [
        "typescript", "javascript", "go", "python", "rust", "java",
        "c", "cpp", "cuda", "sql", "json", "jsonc", "yaml", "toml",
        "xml", "markdown", "shell", "dockerfile", "cypher", "ini", "dotenv"
      ]
    },
    
    "variants": {
      "type": "array",
      "items": { "type": "string" },
      "description": "File extensions (e.g. ['.ts', '.tsx'])"
    },
    
    "metadata": {
      "type": "object",
      "properties": {
        "author": { "type": "string" },
        "created": { "type": "string", "format": "date" },
        "updated": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "parser_status": { 
          "type": "string",
          "enum": ["basic", "functional", "enhanced", "complete"]
        },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    
    "config": {
      "type": "object",
      "properties": {
        "line_tolerance": {
          "type": "integer",
          "minimum": 0,
          "default": 2
        },
        "require_all_symbols": { "type": "boolean", "default": true },
        "allow_extra_symbols": { "type": "boolean", "default": true },
        "validate_signature": { "type": "boolean", "default": false },
        "validate_value": { "type": "boolean", "default": false },
        "validate_parent": { "type": "boolean", "default": true }
      }
    },
    
    "fixture": {
      "type": "object",
      "oneOf": [
        {
          "properties": {
            "type": { "const": "file" },
            "path": { "type": "string" },
            "sha256": { "type": "string" }
          },
          "required": ["type", "path"]
        },
        {
          "properties": {
            "type": { "const": "inline" },
            "content": { "type": "string" },
            "filename": { "type": "string" }
          },
          "required": ["type", "content"]
        }
      ]
    },
    
    "expected": {
      "type": "object",
      "required": ["symbols"],
      "properties": {
        "symbol_count": {
          "oneOf": [
            { "type": "integer" },
            { "type": "object", "properties": { "min": {"type": "integer"}, "max": {"type": "integer"} } }
          ]
        },
        "symbols": {
          "type": "array",
          "items": { "$ref": "#/$defs/Symbol" }
        },
        "excluded": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "name_pattern": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        },
        "relationships": {
          "type": "array",
          "items": { "$ref": "#/$defs/Relationship" }
        }
      }
    },
    
    "patterns_covered": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["P1_CONSTANT", "P2_FUNCTION", "P3_CLASS_STRUCT", "P4_INTERFACE_TRAIT", "P5_ENUM", "P6_METHOD", "P7_TYPE_ALIAS"]
      }
    }
  },
  
  "$defs": {
    "Symbol": {
      "type": "object",
      "required": ["name", "type", "line"],
      "properties": {
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["constant", "function", "class", "method", "interface", "enum", "type", "struct", "trait", "macro", "kernel", "variable", "field"]
        },
        "line": { "type": "integer", "minimum": 1 },
        "line_end": { "type": "integer", "minimum": 1 },
        "exported": { "type": "boolean" },
        "parent": { "type": "string", "description": "Owning class/struct for methods" },
        "extends": { "type": "string", "description": "Base class/interface for inheritance" },
        "signature": { "type": "string" },
        "signature_contains": { "type": "array", "items": { "type": "string" } },
        "value": { "type": "string" },
        "doc_comment": { "type": "string" },
        "decorators": { "type": "array", "items": { "type": "string" } },
        "pattern": { "type": "string" },
        "optional": { "type": "boolean", "default": false },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Relationship": {
      "type": "object",
      "required": ["source", "relation", "target"],
      "properties": {
        "source": { "type": "string" },
        "relation": { "type": "string", "enum": ["DEFINES_METHOD", "EXTENDS", "IMPLEMENTS", "IMPORTS", "CONTAINS"] },
        "target": { "type": "string" }
      }
    }
  }
}
