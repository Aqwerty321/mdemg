{
  "uobs_version": "1.0.0",
  "test": {
    "name": "prometheus_metrics",
    "description": "Validates Prometheus metrics endpoint and required metrics",
    "type": "metrics"
  },
  "metrics": {
    "endpoint": "/v1/prometheus",
    "required_metrics": [
      {
        "name": "mdemg_http_requests_total",
        "type": "counter",
        "labels": ["method", "path", "status"],
        "description": "Total HTTP requests processed"
      },
      {
        "name": "mdemg_http_request_duration_seconds",
        "type": "histogram",
        "labels": ["method", "path"],
        "description": "HTTP request latency distribution"
      },
      {
        "name": "mdemg_retrieval_latency_seconds",
        "type": "histogram",
        "description": "Memory retrieval operation latency"
      },
      {
        "name": "mdemg_retrieval_cache_hits_total",
        "type": "counter",
        "description": "Number of retrieval cache hits"
      },
      {
        "name": "mdemg_retrieval_cache_misses_total",
        "type": "counter",
        "description": "Number of retrieval cache misses"
      },
      {
        "name": "mdemg_rate_limit_rejected_total",
        "type": "counter",
        "description": "Requests rejected by rate limiting"
      },
      {
        "name": "mdemg_circuit_breaker_state",
        "type": "gauge",
        "labels": ["service"],
        "description": "Circuit breaker state (0=closed, 1=open, 2=half-open)"
      },
      {
        "name": "mdemg_cache_hit_ratio",
        "type": "gauge",
        "labels": ["cache"],
        "description": "Cache hit ratio"
      },
      {
        "name": "mdemg_embedding_latency_seconds",
        "type": "histogram",
        "description": "Embedding generation latency"
      }
    ],
    "format_validation": true
  }
}
